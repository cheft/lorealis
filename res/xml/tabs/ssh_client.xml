<brls:Box
    width="auto"
    height="auto"
    axis="column"
    paddingTop="18"
    paddingBottom="12"
    paddingLeft="@style/brls/sidebar/padding_left"
    paddingRight="@style/brls/sidebar/padding_right">

    <brls:Box
        width="auto"
        height="auto"
        axis="row"
        alignItems="center"
        justifyContent="spaceBetween"
        marginBottom="10">

        <brls:Box
            width="auto"
            height="auto"
            axis="column"
            grow="1.0"
            marginRight="14">

            <brls:Label
                width="auto"
                height="auto"
                text="SSH Client"
                fontSize="24"/>

            <brls:Label
                width="auto"
                height="auto"
                text="点击新增主机，使用 user@host:port 录入；点击主机后输入密码并立即打开终端。错误尽量通过通知提示，不打断当前流程。"
                fontSize="14"
                marginTop="8"/>

        </brls:Box>

        <brls:Button
            id="ssh_add_host_button"
            width="180"
            height="auto"
            text="新增主机"
            style="bordered"/>

    </brls:Box>

    <brls:ScrollingFrame
        id="ssh_host_scroll"
        width="auto"
        height="auto"
        grow="1.0">

        <brls:Box
            id="ssh_host_list"
            width="auto"
            height="auto"
            axis="column">

            <brls:Label
                id="ssh_empty_label"
                width="auto"
                height="auto"
                text="当前还没有主机。点击右上角“新增主机”后，录入类似 jax@192.168.31.43:22 的地址即可。"
                fontSize="14"
                marginTop="10"/>

        </brls:Box>

    </brls:ScrollingFrame>

</brls:Box>
