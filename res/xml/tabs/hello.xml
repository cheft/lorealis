<brls:Box
    width="auto"
    height="auto">

    <brls:ScrollingFrame
        width="auto"
        height="auto"
        grow="1.0"
    >
        <brls:Box
            id="hello_box"
            paddingTop="24px"
            paddingBottom="24px"
            paddingLeft="24px"
            paddingRight="24px"
            gap="10px"
            width="auto"
            height="auto"
            axis="column">

            <brls:Label
                id="hello_label"
                width="auto"
                height="auto"
                fontSize="24px"
                horizontalAlign="center"
                text="功能测试页(整个App程序都已使用 Lua+XML 全动态编写)"
                marginBottom="10px" />

            <brls:InputCell
                id="hello_system_input" />

            <brls:DetailCell
                id="hello_overlay_input"
                title="终端虚拟键盘输入框" />

            <brls:InputCell
                id="hello_overlay_ime_bridge"
                visibility="gone" />

            <brls:Button
                id="hello_button"
                width="auto"
                height="auto"
                style="bordered"
                text="测试动态插件 pkgs/hello_view.blpkg"
                focusDown="button_bordered" />
        </brls:Box>

    </brls:ScrollingFrame>
</brls:Box>
